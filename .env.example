# ─── Space-Track.org ───────────────────────────────────────────────────────────
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=

# ─── Celestrak (no auth required, but set base URL for easy swapping) ──────────
CELESTRAK_BASE_URL=https://celestrak.org

# ─── ESA DISCOS ────────────────────────────────────────────────────────────────
ESA_DISCOS_API_KEY=
ESA_DISCOS_BASE_URL=https://discosweb.esac.esa.int/api

# ─── NOAA SWPC (no auth required) ──────────────────────────────────────────────
NOAA_SWPC_BASE_URL=https://services.swpc.noaa.gov

# ─── NASA CDM Feed ─────────────────────────────────────────────────────────────
NASA_CDM_BASE_URL=https://conjunction.nasa.gov

# ─── Databricks ────────────────────────────────────────────────────────────────
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_CLUSTER_ID=
DATABRICKS_CATALOG=drift_zero
DATABRICKS_SCHEMA=orbital

# ─── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── App Config ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
